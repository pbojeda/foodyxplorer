# ===========================================
# Environment Variables Template
# ===========================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# Backend
NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Authentication (if applicable)
# JWT_SECRET=your-secret-here
# JWT_EXPIRES_IN=7d

# Project-specific variables (preserved from previous version)
# Node
# API Server
# PostgreSQL
DATABASE_URL=postgresql://foodxplorer:foodxplorer@localhost:5433/foodxplorer_dev
DATABASE_URL_TEST=postgresql://foodxplorer:foodxplorer@localhost:5433/foodxplorer_test
# Used only by packages/api/scripts/reseed-all-envs.sh. Set DEV; set PROD
# only if you operate the prod Supabase project. Use port 5432 (session
# pooler) per the operational rule in key_facts.md.
DATABASE_URL_DEV=
DATABASE_URL_PROD=
# Redis
REDIS_URL=redis://localhost:6380
# LLM (needed from E003)
# ANTHROPIC_API_KEY=sk-ant-...
# Telegram Bot (needed from E004)
# TELEGRAM_BOT_TOKEN=...
# Embeddings (needed from F019 — POST /embeddings/generate and npm run embeddings:generate)
# OPENAI_API_KEY is required at pipeline invocation time (not at server startup)
# OPENAI_API_KEY=sk-...
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small   # default: text-embedding-3-small (1536-dim)
# OPENAI_EMBEDDING_BATCH_SIZE=100                 # default: 100 (max: 2048)
# OPENAI_EMBEDDING_RPM=3000                       # default: 3000 requests per minute
# API Key Auth (F026)
# ADMIN_API_KEY is required in production (min 32 chars).
# When absent in test/dev, admin auth is skipped.
# Generate a strong key: openssl rand -hex 32
# ADMIN_API_KEY=your-admin-api-key-min-32-chars-here
# BOT_API_KEY_SEED is optional. When set, the seed script generates a
# deterministic API key for the Telegram bot (reproducible across environments).
# When absent, a random key is generated each time.
# BOT_API_KEY_SEED=your-bot-seed-value
# Scraper (packages/scraper — F007+)
SCRAPER_HEADLESS=true
# SCRAPER_CHAIN=mcdonalds-es  # Set to run a specific chain scraper
# F071 — BEDCA Food Database Import
# Set to "true" ONLY after receiving AESAN commercial authorization.
# Enables production seeding of the BEDCA Spanish food composition database.
# Leave unset (or set to false) until authorization is received.
BEDCA_IMPORT_ENABLED=
# F080 — Open Food Facts (OFF) Import
# Set to "true" to enable OFF product import.
OFF_IMPORT_ENABLED=
# OFF API v2 requires authentication. Create an account at https://world.openfoodfacts.org/
# then log in and copy the session cookie from your browser dev tools.
# Format: "session=<cookie-value>"
OFF_SESSION_COOKIE=
# F075 — Voice Input (Whisper transcription)
# Uses OPENAI_API_KEY (set above). No additional keys needed.
# Voice messages are transcribed via OpenAI Whisper API.
# Rate limit: 50 voice messages/day per actor.
# F091 — Voice budget Slack alerts
# When set, fires a webhook when monthly voice spend crosses 40/70/90/100 EUR thresholds.
# Deduplication keys ensure each threshold fires at most once per calendar month.
# DO NOT commit actual webhook — rotatable via Slack app settings.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
