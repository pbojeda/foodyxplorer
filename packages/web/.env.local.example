NEXT_PUBLIC_API_URL=http://localhost:3001

# F113 — Web assistant metrics beacon endpoint. Leave unset to disable.
NEXT_PUBLIC_METRICS_ENDPOINT=

# GA4 Measurement ID — same property as landing, enables cross-domain funnel.
# When unset, GA4 is disabled silently (no script injected, no JS errors).
NEXT_PUBLIC_GA_MEASUREMENT_ID=
