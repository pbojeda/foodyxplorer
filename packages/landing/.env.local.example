# Google Analytics 4 Measurement ID (required for GA4 script)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Public site URL (used in JSON-LD schemas and sitemap)
NEXT_PUBLIC_SITE_URL=https://nutrixplorer.com

# Base URL of the web assistant (e.g., https://hablar.nutrixplorer.com).
# When unset, header/hero/bottom CTAs fall back to #waitlist anchor.
NEXT_PUBLIC_WEB_URL=
