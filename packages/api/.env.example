DATABASE_URL="postgresql://foodxplorer:foodxplorer@localhost:5433/foodxplorer_dev?schema=public"
DATABASE_URL_TEST="postgresql://foodxplorer:foodxplorer@localhost:5433/foodxplorer_test?schema=public"

# Used only by packages/api/scripts/reseed-all-envs.sh — re-applies the seed
# pipeline against Supabase. DEV is required; PROD is required only when the
# script is invoked with --prod. Leave unset if you do not operate the
# deployed environments. Use the Supabase session pooler on port 5432.
DATABASE_URL_DEV=""
DATABASE_URL_PROD=""

# Supabase Auth (F107a — ADR-025 R3)
# SUPABASE_URL: your Supabase project URL (e.g. https://xxx.supabase.co)
SUPABASE_URL=""
# SUPABASE_SERVICE_ROLE_KEY: admin SDK key — used ONLY for /auth/logout.
# NEVER expose in client-side code or NEXT_PUBLIC_* env vars.
SUPABASE_SERVICE_ROLE_KEY=""
# SUPABASE_JWKS_URL: optional — defaults to ${SUPABASE_URL}/auth/v1/.well-known/jwks.json
# Override only if you are using a custom JWKS endpoint.
# SUPABASE_JWKS_URL=""
# SUPABASE_JWT_SECRET: HS256 shared secret — NOT consumed by API code.
# Documented here as operator-only emergency manual verification tool.
# The API ONLY uses RS256+JWKS. No HS256 fallback path exists.
# SUPABASE_JWT_SECRET=""
