{
  "name": "@foodxplorer/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "ingest:batch": "tsx src/scripts/batch-ingest.ts",
    "ingest:batch-images": "tsx src/scripts/batch-ingest-images.ts",
    "quality:report": "tsx src/scripts/quality-monitor.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.1",
    "@foodxplorer/scraper": "^0.0.1",
    "@foodxplorer/shared": "*",
    "@prisma/client": "^6.4.1",
    "crawlee": "^3.0.0",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^4.0.2",
    "ioredis": "^5.4.2",
    "kysely": "^0.27.5",
    "node-html-parser": "^6.0.0",
    "openai": "^6.31.0",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.40.0",
    "tesseract.js": "^5.1.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/pdf-parse": "^1.1.5",
    "ioredis-mock": "^8.13.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.4.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.7"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
