// This is the Prisma schema for foodXPlorer.
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

generator kysely {
  provider     = "prisma-kysely"
  output       = "../src/generated"
  fileName     = "kysely-types.ts"
  enumFileName = "kysely-enums.ts"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum DataSourceType {
  official
  estimated
  scraped
  user

  @@map("data_source_type")
}

enum ConfidenceLevel {
  high
  medium
  low

  @@map("confidence_level")
}

enum EstimationMethod {
  official
  ingredients
  extrapolation
  scraped
  llm

  @@map("estimation_method")
}

enum PortionConfidence {
  high
  medium
  low

  @@map("portion_confidence")
}

enum FoodType {
  generic
  branded
  composite

  @@map("food_type")
}

enum NutrientReferenceBasis {
  per_100g
  per_serving
  per_package

  @@map("nutrient_reference_basis")
}

enum DishAvailability {
  available
  seasonal
  discontinued
  regional

  @@map("dish_availability")
}

enum ApiKeyTier {
  free
  pro

  @@map("api_key_tier")
}

enum ActorType {
  anonymous_web
  telegram
  authenticated

  @@map("actor_type")
}

enum QueryLogLevelHit {
  l1
  l2
  l3
  l4

  @@map("query_log_level_hit")
}

enum QueryLogSource {
  api
  bot

  @@map("query_log_source")
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model DataSource {
  id           String         @id @default(uuid()) @db.Uuid
  name         String         @db.VarChar(255)
  type         DataSourceType
  url          String?        @db.Text
  priorityTier Int?           @map("priority_tier")
  lastUpdated  DateTime?      @map("last_updated")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  foods         Food[]
  foodNutrients FoodNutrient[]
  recipes       Recipe[]
  dishes        Dish[]
  dishNutrients DishNutrient[]

  @@map("data_sources")
}

model Food {
  id              String          @id @default(uuid()) @db.Uuid
  name            String          @db.VarChar(255)
  nameEs          String          @map("name_es") @db.VarChar(255)
  aliases         String[]
  foodGroup       String?         @map("food_group") @db.VarChar(100)
  sourceId        String          @map("source_id") @db.Uuid
  externalId      String?         @map("external_id") @db.VarChar(100)
  confidenceLevel ConfidenceLevel @map("confidence_level")
  foodType        FoodType        @default(generic) @map("food_type")
  brandName       String?         @map("brand_name") @db.VarChar(255)
  barcode         String?         @db.VarChar(50)
  /// @db.Unsupported — pgvector column; use prisma.$queryRaw / $executeRaw for reads/writes
  embedding          Unsupported("vector(1536)")?
  embeddingUpdatedAt DateTime?       @map("embedding_updated_at") @db.Timestamptz
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  source             DataSource        @relation(fields: [sourceId], references: [id])
  foodNutrients     FoodNutrient[]
  recipe            Recipe?
  recipeIngredients  RecipeIngredient[]
  dishes             Dish[]
  dishIngredients    DishIngredient[]

  @@unique([externalId, sourceId])
  @@index([foodType])
  @@index([barcode])
  // Partial index for brandName WHERE NOT NULL is defined in raw SQL migration only
  // (Prisma @@index does not support WHERE clauses)
  @@map("foods")
}

model FoodNutrient {
  id                 String                 @id @default(uuid()) @db.Uuid
  foodId             String                 @map("food_id") @db.Uuid
  calories           Decimal                @db.Decimal(8, 2)
  proteins           Decimal                @db.Decimal(8, 2)
  carbohydrates      Decimal                @db.Decimal(8, 2)
  sugars             Decimal                @db.Decimal(8, 2)
  fats               Decimal                @db.Decimal(8, 2)
  saturatedFats      Decimal                @map("saturated_fats") @db.Decimal(8, 2)
  fiber              Decimal                @db.Decimal(8, 2)
  salt               Decimal                @db.Decimal(8, 2)
  sodium             Decimal                @db.Decimal(8, 2)
  extra              Json?
  referenceBasis     NutrientReferenceBasis @default(per_100g) @map("reference_basis")
  transFats          Decimal                @default(0) @map("trans_fats") @db.Decimal(8, 2)
  cholesterol        Decimal                @default(0) @db.Decimal(8, 2)
  potassium          Decimal                @default(0) @db.Decimal(8, 2)
  monounsaturatedFats Decimal               @default(0) @map("monounsaturated_fats") @db.Decimal(8, 2)
  polyunsaturatedFats Decimal               @default(0) @map("polyunsaturated_fats") @db.Decimal(8, 2)
  alcohol             Decimal               @default(0) @db.Decimal(8, 2)
  sourceId           String                 @map("source_id") @db.Uuid
  confidenceLevel    ConfidenceLevel        @map("confidence_level")
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")

  food   Food       @relation(fields: [foodId], references: [id])
  source DataSource @relation(fields: [sourceId], references: [id])

  @@unique([foodId, sourceId])
  @@map("food_nutrients")
}

/// F-UX-B — Per-dish portion assumption for Spanish serving terms (pintxo/tapa/media ración/ración).
/// Populated offline via LLM + analyst-reviewed CSV seed pipeline.
/// See ADR-020 and packages/api/src/scripts/seedStandardPortionCsv.ts.
model StandardPortion {
  id        String            @id @default(uuid()) @db.Uuid
  dishId    String            @map("dish_id") @db.Uuid
  term      String            @db.VarChar(50)
  grams     Int
  pieces    Int?
  pieceName String?           @map("piece_name") @db.VarChar(100)
  confidence PortionConfidence
  notes     String?           @db.Text
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  dish Dish @relation(fields: [dishId], references: [id], onDelete: Cascade)

  // pieces and pieceName must both be null or both non-null (enforced via SQL CHECK constraint)
  // UNIQUE (dish_id, term) enforced via SQL UNIQUE constraint (see migration SQL)
  @@unique([dishId, term])
  @@map("standard_portions")
}

model Recipe {
  id          String   @id @default(uuid()) @db.Uuid
  foodId      String   @unique @map("food_id") @db.Uuid
  servings    Int?
  prepMinutes Int?     @map("prep_minutes")
  cookMinutes Int?     @map("cook_minutes")
  sourceId    String   @map("source_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  food        Food               @relation(fields: [foodId], references: [id])
  source      DataSource         @relation(fields: [sourceId], references: [id])
  ingredients RecipeIngredient[]

  @@map("recipes")
}

model RecipeIngredient {
  id               String   @id @default(uuid()) @db.Uuid
  recipeId         String   @map("recipe_id") @db.Uuid
  ingredientFoodId String   @map("ingredient_food_id") @db.Uuid
  amount           Decimal  @db.Decimal(8, 2)
  unit             String   @db.VarChar(50)
  gramWeight       Decimal? @map("gram_weight") @db.Decimal(8, 2)
  sortOrder        Int      @map("sort_order")
  notes            String?  @db.Text
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  recipe         Recipe @relation(fields: [recipeId], references: [id], onDelete: Restrict)
  ingredientFood Food   @relation(fields: [ingredientFoodId], references: [id], onDelete: Restrict)

  @@unique([recipeId, ingredientFoodId, sortOrder])
  @@index([recipeId])
  @@index([ingredientFoodId])
  @@map("recipe_ingredients")
}

// ---------------------------------------------------------------------------
// F002 — Restaurants & Dishes
// ---------------------------------------------------------------------------

model CookingMethod {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(255)
  nameEs      String   @map("name_es") @db.VarChar(255)
  slug        String   @unique @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  dishes DishCookingMethod[]

  @@map("cooking_methods")
}

model DishCategory {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(255)
  nameEs      String   @map("name_es") @db.VarChar(255)
  slug        String   @unique @db.VarChar(100)
  description String?  @db.Text
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  dishes DishDishCategory[]

  @@map("dish_categories")
}

model Restaurant {
  id            String   @id @default(uuid()) @db.Uuid
  name          String   @db.VarChar(255)
  nameEs        String?  @map("name_es") @db.VarChar(255)
  chainSlug     String   @map("chain_slug") @db.VarChar(100)
  website       String?  @db.Text
  logoUrl       String?  @map("logo_url") @db.Text
  countryCode   String   @default("ES") @map("country_code") @db.VarChar(2)
  isActive      Boolean  @default(true) @map("is_active")
  address       String?  @db.VarChar(500)
  googleMapsUrl String?  @map("google_maps_url") @db.Text
  latitude      Decimal? @db.Decimal(10, 7)
  longitude     Decimal? @db.Decimal(10, 7)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  dishes Dish[]

  @@unique([chainSlug, countryCode])
  @@map("restaurants")
}

model Dish {
  id               String           @id @default(uuid()) @db.Uuid
  restaurantId     String           @map("restaurant_id") @db.Uuid
  foodId           String?          @map("food_id") @db.Uuid
  sourceId         String           @map("source_id") @db.Uuid
  name             String           @db.VarChar(255)
  nameEs           String?          @map("name_es") @db.VarChar(255)
  nameSourceLocale String?          @map("name_source_locale") @db.VarChar(16)
  description      String?          @db.Text
  externalId       String?          @map("external_id") @db.VarChar(100)
  availability     DishAvailability @default(available)
  portionGrams     Decimal?         @map("portion_grams") @db.Decimal(8, 2)
  priceEur         Decimal?         @map("price_eur") @db.Decimal(8, 2)
  confidenceLevel  ConfidenceLevel  @map("confidence_level")
  estimationMethod EstimationMethod @map("estimation_method")
  aliases          String[]
  /// @db.Unsupported — pgvector column; use prisma.$queryRaw / $executeRaw for reads/writes
  embedding          Unsupported("vector(1536)")?
  embeddingUpdatedAt DateTime?        @map("embedding_updated_at") @db.Timestamptz
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  restaurant     Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Restrict)
  food           Food?              @relation(fields: [foodId], references: [id], onDelete: SetNull)
  source         DataSource         @relation(fields: [sourceId], references: [id], onDelete: Restrict)
  nutrients             DishNutrient[]
  ingredients           DishIngredient[]
  cookingMethods        DishCookingMethod[]
  categories            DishDishCategory[]
  missedQueryTrackings  MissedQueryTracking[]
  standardPortions      StandardPortion[]

  // Partial indexes (food_id WHERE NOT NULL, FTS, aliases GIN) defined in raw SQL migration only
  @@index([restaurantId])
  @@index([availability])
  @@map("dishes")
}

model DishNutrient {
  id                  String                 @id @default(uuid()) @db.Uuid
  dishId              String                 @map("dish_id") @db.Uuid
  calories            Decimal                @db.Decimal(8, 2)
  proteins            Decimal                @db.Decimal(8, 2)
  carbohydrates       Decimal                @db.Decimal(8, 2)
  sugars              Decimal                @db.Decimal(8, 2)
  fats                Decimal                @db.Decimal(8, 2)
  saturatedFats       Decimal                @map("saturated_fats") @db.Decimal(8, 2)
  fiber               Decimal                @db.Decimal(8, 2)
  salt                Decimal                @db.Decimal(8, 2)
  sodium              Decimal                @db.Decimal(8, 2)
  extra               Json?
  referenceBasis      NutrientReferenceBasis @default(per_serving) @map("reference_basis")
  transFats           Decimal                @default(0) @map("trans_fats") @db.Decimal(8, 2)
  cholesterol         Decimal                @default(0) @db.Decimal(8, 2)
  potassium           Decimal                @default(0) @db.Decimal(8, 2)
  monounsaturatedFats Decimal                @default(0) @map("monounsaturated_fats") @db.Decimal(8, 2)
  polyunsaturatedFats Decimal                @default(0) @map("polyunsaturated_fats") @db.Decimal(8, 2)
  alcohol             Decimal                @default(0) @db.Decimal(8, 2)
  estimationMethod    EstimationMethod       @map("estimation_method")
  sourceId            String                 @map("source_id") @db.Uuid
  confidenceLevel     ConfidenceLevel        @map("confidence_level")
  createdAt           DateTime               @default(now()) @map("created_at")
  updatedAt           DateTime               @updatedAt @map("updated_at")

  // calories upper bound 9000 enforced only in raw SQL CHECK (Prisma has no max check)
  dish   Dish       @relation(fields: [dishId], references: [id], onDelete: Restrict)
  source DataSource @relation(fields: [sourceId], references: [id], onDelete: Restrict)

  @@unique([dishId, sourceId])
  @@index([sourceId])
  @@map("dish_nutrients")
}

model DishIngredient {
  id               String   @id @default(uuid()) @db.Uuid
  dishId           String   @map("dish_id") @db.Uuid
  ingredientFoodId String   @map("ingredient_food_id") @db.Uuid
  amount           Decimal  @db.Decimal(8, 2)
  unit             String   @db.VarChar(50)
  gramWeight       Decimal? @map("gram_weight") @db.Decimal(8, 2)
  sortOrder        Int      @map("sort_order")
  notes            String?  @db.Text
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  dish           Dish @relation(fields: [dishId], references: [id], onDelete: Restrict)
  ingredientFood Food @relation(fields: [ingredientFoodId], references: [id], onDelete: Restrict)

  @@unique([dishId, ingredientFoodId, sortOrder])
  @@index([dishId])
  @@index([ingredientFoodId])
  @@map("dish_ingredients")
}

model DishCookingMethod {
  dishId          String @map("dish_id") @db.Uuid
  cookingMethodId String @map("cooking_method_id") @db.Uuid

  dish          Dish          @relation(fields: [dishId], references: [id], onDelete: Cascade)
  cookingMethod CookingMethod @relation(fields: [cookingMethodId], references: [id], onDelete: Restrict)

  @@id([dishId, cookingMethodId])
  @@index([cookingMethodId])
  @@map("dish_cooking_methods")
}

model DishDishCategory {
  dishId         String @map("dish_id") @db.Uuid
  dishCategoryId String @map("dish_category_id") @db.Uuid

  dish         Dish         @relation(fields: [dishId], references: [id], onDelete: Cascade)
  dishCategory DishCategory @relation(fields: [dishCategoryId], references: [id], onDelete: Restrict)

  @@id([dishId, dishCategoryId])
  @@index([dishCategoryId])
  @@map("dish_dish_categories")
}

// ---------------------------------------------------------------------------
// F026 — API Keys
// ---------------------------------------------------------------------------

model ApiKey {
  id         String     @id @default(uuid()) @db.Uuid
  keyHash    String     @unique @map("key_hash") @db.VarChar(64)
  keyPrefix  String     @map("key_prefix") @db.VarChar(8)
  name       String     @db.VarChar(255)
  tier       ApiKeyTier @default(free)
  isActive   Boolean    @default(true) @map("is_active")
  expiresAt  DateTime?  @map("expires_at") @db.Timestamptz
  lastUsedAt DateTime?  @map("last_used_at") @db.Timestamptz
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  @@index([keyPrefix])
  @@map("api_keys")
}

// ---------------------------------------------------------------------------
// F069 — Actors (Anonymous Identity)
// ---------------------------------------------------------------------------

model Actor {
  id         String    @id @default(uuid()) @db.Uuid
  type       ActorType
  externalId String    @map("external_id") @db.VarChar(255)
  locale     String?   @db.VarChar(10)
  createdAt  DateTime  @default(now()) @map("created_at")
  lastSeenAt DateTime  @default(now()) @map("last_seen_at") @db.Timestamptz

  @@unique([type, externalId])
  @@map("actors")
}

// ---------------------------------------------------------------------------
// F029 — Query Logs
// ---------------------------------------------------------------------------

model QueryLog {
  id             String            @id @default(uuid()) @db.Uuid
  queryText      String            @map("query_text") @db.VarChar(255)
  chainSlug      String?           @map("chain_slug") @db.VarChar(100)
  restaurantId   String?           @map("restaurant_id") @db.Uuid
  levelHit       QueryLogLevelHit? @map("level_hit")
  cacheHit       Boolean           @map("cache_hit")
  responseTimeMs Int               @map("response_time_ms")
  apiKeyId       String?           @map("api_key_id") @db.Uuid
  actorId        String?           @map("actor_id") @db.Uuid
  source         QueryLogSource    @default(api)
  queriedAt      DateTime          @default(now()) @map("queried_at") @db.Timestamptz

  // No @relation on restaurantId / apiKeyId — immutable audit records,
  // no FK constraints intentionally omitted.

  @@index([queriedAt(sort: Desc)])
  @@index([chainSlug])
  @@index([levelHit])
  @@index([source])
  @@map("query_logs")
}

// ---------------------------------------------------------------------------
// F079 — Missed Query Tracking (Demand-Driven Expansion Pipeline)
// ---------------------------------------------------------------------------

enum MissedQueryStatus {
  pending
  resolved
  ignored

  @@map("missed_query_status")
}

model MissedQueryTracking {
  id             String             @id @default(uuid()) @db.Uuid
  queryText      String             @unique @map("query_text") @db.VarChar(255)
  hitCount       Int                @map("hit_count")
  status         MissedQueryStatus  @default(pending)
  resolvedDishId String?            @map("resolved_dish_id") @db.Uuid
  notes          String?            @db.Text
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  resolvedDish   Dish?              @relation(fields: [resolvedDishId], references: [id])

  @@index([status])
  @@map("missed_query_tracking")
}

model WaitlistSubmission {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email       String   @unique
  phone       String?
  variant     String   @default("a")
  source      String   @default("hero")
  utmSource   String?  @map("utm_source")
  utmMedium   String?  @map("utm_medium")
  utmCampaign String?  @map("utm_campaign")
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("waitlist_submissions")
}

// ---------------------------------------------------------------------------
// F113 — Web Metrics Events
// ---------------------------------------------------------------------------

model WebMetricsEvent {
  id                String   @id @default(uuid()) @db.Uuid
  queryCount        Int      @map("query_count")
  successCount      Int      @map("success_count")
  errorCount        Int      @map("error_count")
  retryCount        Int      @map("retry_count")
  intents           Json     @map("intents")
  errors            Json     @map("errors")
  avgResponseTimeMs Int      @map("avg_response_time_ms")
  sessionStartedAt  DateTime @map("session_started_at") @db.Timestamptz
  receivedAt        DateTime @default(now()) @map("received_at") @db.Timestamptz
  ipHash            String?  @map("ip_hash") @db.VarChar(64)

  @@index([receivedAt(sort: Desc)])
  @@map("web_metrics_events")
}

// ---------------------------------------------------------------------------
// F072 — Cooking Profiles + Yield Factors
// ---------------------------------------------------------------------------

model CookingProfile {
  id            String   @id @default(uuid()) @db.Uuid
  foodGroup     String   @map("food_group") @db.VarChar(100)
  foodName      String   @default("*") @map("food_name") @db.VarChar(255)
  cookingMethod String   @map("cooking_method") @db.VarChar(100)
  yieldFactor   Decimal  @map("yield_factor") @db.Decimal(6, 4)
  fatAbsorption Decimal? @map("fat_absorption") @db.Decimal(6, 2)
  source        String   @db.VarChar(255)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([foodGroup, foodName, cookingMethod])
  @@index([foodGroup])
  @@index([foodName])
  @@map("cooking_profiles")
}
