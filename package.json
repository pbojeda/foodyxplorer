{
  "name": "foodxplorer",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/api",
    "packages/bot",
    "packages/scraper",
    "packages/landing",
    "packages/web"
  ],
  "scripts": {
    "dev:api": "npm run dev -w @foodxplorer/api",
    "dev:bot": "npm run dev -w @foodxplorer/bot",
    "dev:web": "npm run dev -w @foodxplorer/web",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "test": "npm run test --workspaces --if-present",
    "test:coverage": "npm run test:coverage -w @foodxplorer/api",
    "db:migrate": "npm run db:migrate -w @foodxplorer/api",
    "db:push": "npm run db:push -w @foodxplorer/api",
    "db:seed": "npm run db:seed -w @foodxplorer/api",
    "db:studio": "npm run db:studio -w @foodxplorer/api",
    "scraper:run": "npm run dev -w @foodxplorer/scraper",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v && docker compose up -d"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "next": "^14.2.29"
  }
}
